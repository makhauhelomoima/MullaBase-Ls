'use client'
import { useEffect } from 'react'
import { createClient } from '@supabase/supabase-js'
const supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY)
export default function Engage() {
  useEffect(() => { supabase.auth.getUser().then(({data:{user}}) => !user && (window.location.href = '/') ) }, [])
  return (
    <main className="min-h-screen bg-white text-black text-sm">
      <div className="border-b border-black p-2 flex justify-between"><span className="font-bold">MullaBase Engage Hub</span><a href="/dashboard" className="border border-black px-2">Dashboard</a></div>
      <div className="p-4 grid grid-cols-2 gap-2">
        {[
          {n:'POST & ENGAGE BLOG',p:'/post',d:'Write posts up to 1000 words. No ads or links.'},
          {n:'SWAP 2 OWN BLOG',p:'/swap',d:'Post items to swap. 150 words max.'},
          {n:'FIND A HELP/NANNY',p:'/nanny',d:'Free blog for jobseekers.'},
          {n:'CREATE YOUR STORE',p:'/store',d:'Store owners post links.'}
        ].map(t => <a key={t.n} href={t.p} className="border border-black p-4 block"><div className="font-bold text-lg">{t.n}</div><div className="text-xs mt-1">{t.d}</div></a>)}
      </div>
    </main>
  )
}
